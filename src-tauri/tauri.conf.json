{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "nametag-generator",
    "version": "0.1.0",
    "identifier": "com.marcell-ziegler.nametag-generator",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../src/dist",
        "devUrl": "http://localhost:5173"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "nametag-generator",
                "width": 800,
                "height": 600
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
